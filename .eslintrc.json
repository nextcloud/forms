{
	"globals": {
		"appName": true
	},
	"extends": [
		"@nextcloud",
		"prettier"
	],
	"rules": {
		// We are using the @nextcloud/logger
		"no-console": "error",
		"import/no-unresolved": ["error", { "ignore": ["\\?raw"] }]
	},
	"overrides": [
		{
			"files": ["**/*.vue"],
			"rules": {
				"vue/first-attribute-linebreak": "off"
			}
		}
	]
}
